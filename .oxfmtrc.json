{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"sortTailwindcss": {},
	"useTabs": true,
	"singleQuote": true,
	"trailingComma": "none",
	"printWidth": 100,
	"sortPackageJson": false,
	"ignorePatterns": [
		"CHANGELOG.md",
		"pnpm-lock.yaml",
		"**/.svelte-kit/",
		"**/build/",
		"**/dist/",
		".claude/"
	]
}
