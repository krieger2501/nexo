PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<key>

# Drizzle migrations — Supabase direct Postgres connection (Transaction mode / port 6543)
# Get from: Supabase → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# OAuth redirect URLs to add in Supabase → Authentication → URL Configuration:
#   Site URL:              https://your-production-domain.pages.dev
#   Redirect URL (prod):   https://your-production-domain.pages.dev/auth/callback
#   Redirect URL (local):  http://localhost:5173/auth/callback
#
# Allowlist:    Supabase → Authentication → Sign In / Up → Restricted sign ups (add permitted emails)
# Google:       Supabase → Authentication → Providers → Google  (Client ID + Secret from Google Cloud Console)
# Apple:        Supabase → Authentication → Providers → Apple   (Service ID + Key from Apple Developer Portal)
