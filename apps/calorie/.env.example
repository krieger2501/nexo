# Local development overrides for the calorie app.
# Copy to .env and fill in. The root .env is also loaded for shared values
# (DATABASE_URL, BETTER_AUTH_SECRET).

# Required — must match values from the root .env
# DATABASE_URL=postgres://nexo:changeme@localhost:5433/nexo
# BETTER_AUTH_SECRET=<same value as root .env>

# Where the auth app is reachable in this environment
# PUBLIC_AUTH_URL=http://localhost:3001

# This app's own public URL (used to build redirect-back URLs)
# PUBLIC_CALORIE_URL=http://localhost:3007

# Landing page URL (used for "back to landing" affordances)
# PUBLIC_LANDING_URL=http://localhost:3000
