{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",
		"declaration": true,
		"declarationDir": "./dist",
		"moduleResolution": "bundler",
		"module": "ESNext",
		"target": "ESNext",
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"allowJs": true
	},
	"include": ["src/**/*"]
}
