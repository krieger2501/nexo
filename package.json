{
	"name": "nexo",
	"version": "0.8.4",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "turbo build",
		"build:packages": "turbo build --filter='./packages/*'",
		"clean": "del '{apps,packages}/*/{build,dist,.svelte-kit,.turbo}' 'apps/*/src/lib/paraglide' .turbo",
		"clean:deps": "del '{apps,packages}/*/node_modules' node_modules",
		"db:generate": "turbo db:generate --filter=@nexo/db",
		"db:migrate": "turbo db:migrate --filter=@nexo/db",
		"db:studio": "turbo db:studio --filter=@nexo/db",
		"dev": "turbo dev --filter=!@nexo/bot",
		"docker:db": "docker compose --profile production up postgres -d",
		"docker:down": "docker compose --profile production down",
		"docker:logs": "docker compose logs -f",
		"docker:observe": "docker compose --profile server up loki grafana -d",
		"docker:observe:down": "docker compose --profile server down loki grafana",
		"docker:up": "docker compose --profile production up --build",
		"docker:up:prod": "docker compose --profile server -f docker-compose.yml up -d --build",
		"docker:up:server": "docker compose --profile server up --build",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"knip": "knip",
		"lint": "oxlint && turbo lint",
		"package:check": "sort-package-json --check \"{apps,packages,tools}/*/package.json\" package.json",
		"package:format": "sort-package-json \"{apps,packages,tools}/*/package.json\" package.json",
		"prepare": "simple-git-hooks",
		"preview": "turbo preview",
		"qc": "run-s package:check format:check sync translate build knip lint type:check test",
		"sync": "pnpm --filter './apps/*' --filter '!@nexo/bot' exec svelte-kit sync",
		"test": "turbo test:unit",
		"test:e2e": "turbo test:e2e",
		"translate": "pnpm --filter './apps/*' --filter '!@nexo/bot' run translate",
		"translate:watch": "pnpm --filter './apps/*' --filter '!@nexo/bot' --parallel run translate:watch",
		"type:check": "turbo type:check"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm exec lint-staged"
	},
	"lint-staged": {
		"*.{js,ts,mjs,cjs,svelte,svelte.ts,svelte.js}": "oxlint --fix",
		"*.{js,ts,mjs,cjs,json,jsonc,md}": "oxfmt"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@nexo/cli": "workspace:*",
		"@typescript/native-preview": "7.0.0-dev.20260523.1",
		"del-cli": "^7.0.0",
		"eslint": "^10.4.0",
		"eslint-plugin-svelte": "^3.17.1",
		"knip": "^6.14.2",
		"lint-staged": "^17.0.5",
		"npm-run-all2": "^9.0.1",
		"oxfmt": "^0.52.0",
		"oxlint": "^1.67.0",
		"simple-git-hooks": "^2.13.1",
		"sort-package-json": "^3.6.1",
		"tsdown": "^0.22.0",
		"turbo": "^2.9.15",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.0",
		"vite": "catalog:"
	},
	"packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215",
	"engines": {
		"node": ">=24.0.0",
		"pnpm": ">=10.0.0"
	}
}
